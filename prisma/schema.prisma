// Helping Hands — data model
// SQLite by default for zero-config local/demo use.
// Swap provider to "postgresql" + set DATABASE_URL for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  DONOR
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum VolunteerStatus {
  PENDING
  CONFIRMED
  COMPLETED
  WITHDRAWN
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(DONOR)
  createdAt    DateTime   @default(now())
  campaigns    Campaign[] @relation("CampaignOrganizer")
}

model Campaign {
  id            String          @id @default(uuid())
  title         String
  description   String
  category      String
  goalAmount    Float
  raisedAmount  Float           @default(0)
  status        CampaignStatus  @default(ACTIVE)
  deadline      DateTime?
  organizerId   String
  organizer     User            @relation("CampaignOrganizer", fields: [organizerId], references: [id])
  donations     Donation[]
  volunteers    VolunteerCommitment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([category])
}

model Donation {
  id          String   @id @default(uuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorName   String
  donorEmail  String
  amount      Float
  message     String?
  anonymous   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([campaignId])
}

model VolunteerCommitment {
  id             String          @id @default(uuid())
  campaignId     String
  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name           String
  email          String
  role           String
  hoursCommitted Float
  status         VolunteerStatus @default(PENDING)
  createdAt      DateTime        @default(now())

  @@index([campaignId])
}
